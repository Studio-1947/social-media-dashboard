# Social Flow — server environment
#
# NOTE: these values silently drift between local / Vercel / VPS, because .env
# files don't travel with `git push`. A wrong value here does NOT crash the app —
# it degrades to badged sample data. That failure mode once went unnoticed for
# two weeks. After changing anything below, check the boot log for
# "[Metricool] OK — ..." and hit GET /health.

PORT=5000

# Comma-separated allowed browser origins for CORS.
FRONTEND_URLS=http://localhost:5173,http://localhost:3000

# --- Auth / user whitelist -----------------------------------------------------
#
# Without DATABASE_URL and JWT_SECRET, nobody can log in and every
# /api/metricool request 503s (those routes require auth now). Check the boot
# log for "[Auth] Bootstrapped admin account: ..." after first setting these.

# Set by docker-compose automatically when running via `docker compose up` —
# only needed here for running the server outside Docker.
DATABASE_URL=postgres://socialflow:socialflow_dev_only@localhost:5432/socialflow

# Signs session tokens. Any long random string; treat it like a password —
# rotating it instantly logs out every session.
JWT_SECRET=change_this_to_a_long_random_string

# The FIRST admin account, created automatically at boot if the users table has
# no admin yet. Change the password after logging in — this stays in .env as a
# recovery path (locked out? set these, restart, you have an admin again), not
# as an account you keep using day to day.
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=change_this_before_first_boot

# --- Metricool ---------------------------------------------------------------

METRICOOL_BASE_URL=https://app.metricool.com

# Settings -> API in Metricool's UI. Account-wide; one token covers every client.
METRICOOL_API_TOKEN=your_metricool_api_token_here

# Numeric, account-wide. Identical for every brand/client on the account.
METRICOOL_USER_ID=your_numeric_user_id_here

# Numeric blogId of the DEFAULT client, used only when a request omits blogId.
# Every real request from the dashboard carries an explicit blogId from the
# client switcher — this is a fallback, not the operating mode.
METRICOOL_BLOG_ID=your_default_numeric_blog_id_here

METRICOOL_DEFAULT_TIMEZONE=Asia/Kolkata
